{
  "name": "focus-flow-pomodoro",
  "displayName": "FlowBoard - Task Workspace",
  "description": "A task-first workspace with optional pomodoro timer and matrix ambience.",
  "version": "0.1.0",
  "publisher": "nickhilster",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "pomodoro",
    "timer",
    "focus",
    "productivity"
  ],
  "activationEvents": [],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "focusFlow.openTimer",
        "title": "FlowBoard: Open Task Workspace",
        "icon": "$(clock)"
      },
      {
        "command": "focusFlow.quickAddTaskFromSelection",
        "title": "FlowBoard: Quick Add Task from Selection",
        "icon": "$(add)"
      },
      {
        "command": "focusFlow.quickAddTaskFromActiveFile",
        "title": "FlowBoard: Quick Add Task from Active File",
        "icon": "$(file)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "focusFlow.openTimer",
          "group": "navigation@-999"
        },
        {
          "command": "focusFlow.quickAddTaskFromSelection",
          "when": "editorHasSelection",
          "group": "navigation@-998"
        },
        {
          "command": "focusFlow.quickAddTaskFromActiveFile",
          "group": "navigation@-997"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "focusFlow",
          "title": "FlowBoard",
          "icon": "media/icon-light.svg"
        }
      ]
    },
    "views": {
      "focusFlow": [
        {
          "id": "focusFlowView",
          "name": "FlowBoard",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "sync:webview": "node scripts/sync-webview.js",
    "prepackage": "npm run sync:webview",
    "package": "npx -y @vscode/vsce package --no-dependencies",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vitest": "^1.4.5"
  }
}

